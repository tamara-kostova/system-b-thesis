# Copy to .env and fill in values

# --- LLM Provider ---
# Options: anthropic | openai | ollama
LLM_PROVIDER=ollama

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (local — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic model (when LLM_PROVIDER=anthropic)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database ---
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://omop_admin:changeme@localhost:5432/omop

# --- Discovery API ---
DISCOVERY_API_URL=http://localhost:8001

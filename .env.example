# Copy to .env and fill in values before running make start

# ── LLM Provider ───────────────────────────────────────────────────────────────
# Options: anthropic | openai | ollama
LLM_PROVIDER=ollama

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (local — no key needed, default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://omop_admin:changeme@localhost:5433/omop

# ── SPE ────────────────────────────────────────────────────────────────────────
# Random secret used to pseudonymise person_id in permit-scoped views
PROJECTION_SALT=change-this-to-a-random-secret

# Docker container name for the Postgres instance (see docker compose ps)
POSTGRES_CONTAINER_NAME=system-b-thesis-postgres-1

# Docker image for SPE JupyterLab containers
SPE_IMAGE=system-b-spe:latest

# ── Auth ───────────────────────────────────────────────────────────────────────
# Required — no default. Used by the reviewer UIs and the airlock approve/reject endpoints.
REVIEWER_PASSWORD=

# Optional — shared secret for internal service-to-service calls (GET /permits).
# Leave blank to disable the check (open for prototype use).
INTERNAL_API_KEY=

# ── Service URLs ───────────────────────────────────────────────────────────────
# These defaults match the ports assigned in start.sh — only change if you
# run services on different ports.
PERMIT_SERVICE_URL=http://localhost:8002
DISCOVERY_API_URL=http://localhost:8003
AIRLOCK_URL=http://localhost:8005
LLM_GATEWAY_URL=http://localhost:8006
